{
  "name": "job-bot",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "job-bot",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*",
        "convex"
      ],
      "devDependencies": {
        "typescript": "^5.9.3"
      }
    },
    "apps/web": {
      "name": "@job-bot/web",
      "version": "0.1.0"
    },
    "apps/worker": {
      "name": "@job-bot/worker",
      "version": "0.1.0",
      "dependencies": {
        "@job-bot/agent-core": "0.1.0",
        "@job-bot/shared": "0.1.0"
      }
    },
    "convex": {
      "name": "@job-bot/convex",
      "version": "0.1.0"
    },
    "node_modules/@job-bot/agent-core": {
      "resolved": "packages/agent-core",
      "link": true
    },
    "node_modules/@job-bot/convex": {
      "resolved": "convex",
      "link": true
    },
    "node_modules/@job-bot/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@job-bot/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/@job-bot/worker": {
      "resolved": "apps/worker",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/agent-core": {
      "name": "@job-bot/agent-core",
      "version": "0.1.0",
      "dependencies": {
        "@job-bot/shared": "0.1.0"
      }
    },
    "packages/shared": {
      "name": "@job-bot/shared",
      "version": "0.1.0"
    }
  }
}
