{
  "name": "job-bot",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*", "convex"],
  "scripts": {
    "install:all": "npm install --workspaces",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev:all": "concurrently -n convex,web,worker -c cyan,magenta,yellow \"npx convex dev\" \"npm run dev --workspace @job-bot/web\" \"WORKER_HTTP_TRIGGER_PORT=3999 WORKER_USE_CHROME=1 WORKER_CHROME_HEADLESS=0 npm run dev --workspace @job-bot/worker\"",
    "trigger:linkedin": "node --env-file=.env.local scripts/trigger-linkedin-run.mjs",
    "populate:ranking-catalog": "node --env-file=.env.local scripts/populate-ranking-llm-catalog.mjs",
    "backfill:ranking-dimensions": "npx convex run rankingMigrate:startBackfill",
    "test:worker": "npm run test --workspace=@job-bot/worker"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "convex": "^1.36.1"
  }
}
