{
  "name": "@job-bot/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "npm run build && node --env-file=../../.env.local dist/index.js",
    "start": "node --env-file=../../.env.local dist/index.js",
    "build": "npm run build --workspace=@job-bot/agent-core --prefix ../.. && tsc -p tsconfig.json && node -e \"const fs=require('node:fs');for(const f of ['linkedinScrapeInpage.js','linkedinSearchUi.js','linkedinScrapeClickTargets.js'])fs.copyFileSync('src/sources/'+f,'dist/sources/'+f)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test src/sources/linkedinScrapeInpage.test.js src/sources/linkedinScrapeBundle.test.js src/sources/linkedinSearchCriteria.test.js src/sources/linkedinSearchUi.test.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@job-bot/agent-core": "0.1.0",
    "@job-bot/shared": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jsdom": "^26.0.0"
  }
}
