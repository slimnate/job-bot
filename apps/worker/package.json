{
  "name": "@job-bot/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "npm run build && node --env-file=../../.env.local dist/index.js",
    "start": "node --env-file=../../.env.local dist/index.js",
    "build": "npm run build --workspace=@job-bot/agent-core --prefix ../.. && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@job-bot/agent-core": "0.1.0",
    "@job-bot/shared": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
